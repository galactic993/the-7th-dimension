{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:stop; nohup concurrently \"npx convex dev\" \"vite dev\" --names \"convex,vite\" --prefix name > dev.log 2>&1 & echo \"Development servers started. Check dev.log for output.\"",
    "dev:stop": "pkill -f \"convex dev\" && pkill -f \"vite dev\" && rm dev.log && echo \"Development servers stopped.\"",
    "dev:logs": "cat dev.log",
    "build": "vite build",
    "format": "biome format --write .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:convex": "vitest --config vitest.convex.config.ts",
    "test:convex:coverage": "vitest --config vitest.convex.config.ts --coverage",
    "import:users": "tsx scripts/import-users.ts",
    "import:all": "tsx scripts/import-all-users.ts",
    "delete:users": "tsx scripts/delete-all-users.ts"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@clerk/clerk-react": "^5.33.0",
    "@clerk/localizations": "^3.18.0",
    "@clerk/themes": "^2.2.55",
    "@convex-dev/auth": "^0.0.87",
    "@types/node": "^24.0.14",
    "convex": "^1.25.2",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dotenv": "^6.1.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "biome": "^0.2.2",
    "concurrently": "^9.2.0",
    "convex-test": "^0.0.38",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
